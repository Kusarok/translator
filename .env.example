HOST=0.0.0.0
PORT=8080
PORTS=8080
TRUST_PROXY=
MAX_TEXT_LENGTH=8000

DEFAULT_PROVIDER=

CEREBRAS_API_KEY=
OPENROUTER_API_KEY=
GOOGLE_API_KEY=

# Set both to protect the API keys above behind an owner login on public deployments.
# Visitors without these credentials can still use the app with their own API key (BYOK).
# Leave both empty for local/private use, where the app behaves as it did before (no login required).
OWNER_USERNAME=
OWNER_PASSWORD=
# How long an owner login session stays valid, in hours (default 720 = 30 days).
SESSION_TTL_HOURS=720

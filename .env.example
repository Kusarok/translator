HOST=0.0.0.0
PORT=8080
PORTS=8080
TRUST_PROXY=
MAX_TEXT_LENGTH=8000

# Private loopback media-worker service. The browser only uses /api/media on the main app.
MEDIA_WORKER_URL=http://127.0.0.1:8090
RADIO_WORKER_URL=http://127.0.0.1:8091
MEDIA_WORKER_HOST=127.0.0.1
MEDIA_WORKER_PORT=8090
MEDIA_STORAGE_DIR=
MEDIA_MAX_BYTES=367001600
MEDIA_MAX_DURATION_SECONDS=3600
MEDIA_JOB_TIMEOUT_MS=1200000
MEDIA_RETENTION_HOURS=24
MEDIA_MAX_CONCURRENT=1
MEDIA_MAX_CONCURRENT_SEARCHES=2
MEDIA_SEARCH_CACHE_MINUTES=30

DEFAULT_PROVIDER=

CEREBRAS_API_KEY=
OPENROUTER_API_KEY=
GOOGLE_API_KEY=

# --- Groq (owner-only key) ---
# Powers fast Groq chat/translation models AND voice-to-text (Whisper).
# OWNER-ONLY: sits behind the owner login gate below, so anonymous and free-tier
# visitors can never spend it (for chat/translation or transcription). Other users
# bring their own Groq key via Settings. Get one at https://console.groq.com/keys
# The 🎙️ audio button and Groq models only appear when Groq is available (owner key
# here, or a visitor's own Groq key). FREE_PROVIDER can NOT be set to groq.
GROQ_API_KEY=
# Groq OpenAI-compatible endpoint (rarely needs changing).
GROQ_BASE_URL=https://api.groq.com/openai/v1
# Whisper STT model: whisper-large-v3-turbo (default, fast/cheap) or whisper-large-v3 (accurate).
GROQ_STT_MODEL=whisper-large-v3-turbo

# --- Free tier (shared, server-funded) ---
# Let anonymous visitors use ONE server-funded model for free, without a key and without
# logging in. Requires the FREE_PROVIDER key above to be set. Every visitor is rate limited,
# the model is locked, and output is capped so the shared key cannot be abused or drained.
# The key itself is never sent to the browser.
FREE_TIER_ENABLED=true
FREE_PROVIDER=cerebras
FREE_MODEL=gemma-4-31b
# Free requests per visitor per minute (translate + chat share this budget).
FREE_RATE_LIMIT=5
# Hard caps applied to every free request.
FREE_MAX_TOKENS=2048
FREE_MAX_IMAGES=2
# Max total input characters (all chat message text + system prompt) per free request.
FREE_MAX_INPUT_CHARS=16000
# IMPORTANT: behind a reverse proxy, set TRUST_PROXY (above) so the limit is per-visitor
# (real client IP) and not shared across everyone behind the proxy.

# Optional legacy owner credentials. Regular users create their own account in the app.
OWNER_USERNAME=
OWNER_PASSWORD=
# How long a user login session stays valid, in hours (default 720 = 30 days).
SESSION_TTL_HOURS=720
# Google login (create a Web application OAuth client in Google Cloud).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must exactly match the authorized redirect URI in Google Cloud.
# Example: https://your-domain.example/api/auth/google/callback
GOOGLE_REDIRECT_URI=
# A user can prepare at most this many uncached songs per UTC day. Cached music is unlimited.
DAILY_NEW_SONG_LIMIT=5
# Spotify account connection for Learn playlists
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# Example: https://your-domain.example/api/media/spotify/callback
SPOTIFY_REDIRECT_URI=
